file_mode = 2
access = 2
use_native_dialog = true

[node name="MigratePathsDialog" type="ConfirmationDialog" parent="."]
oversampling_override = 1.0
title = "Перепривязка путей"
initial_position = 1
size = Vector2i(271, 100)
borderless = true
ok_button_text = "Обновить"
dialog_text = "Перепривязка путей"
dialog_close_on_escape = false
cancel_button_text = "Отмена"

[connection signal="pressed" from="ContentVBox/ResetBPMBatchButton" to="." method="_on_reset_bpm_batch_pressed"]
[connection signal="pressed" from="ContentVBox/ClearAllCacheButton" to="." method="_on_clear_all_cache_pressed"]
[connection signal="pressed" from="ContentVBox/ClearNotesButton" to="." method="_on_clear_notes_pressed"]
[connection signal="pressed" from="ContentVBox/ResetAllSettingsButton" to="." method="_on_reset_all_settings_pressed"]
[connection signal="pressed" from="ContentVBox/ResetProfileStatsButton" to="." method="_on_reset_profile_stats_pressed"]
[connection signal="toggled" from="ContentVBox/DebugMenuCheckBox" to="." method="_on_debug_menu_toggled"]
[connection signal="toggled" from="ContentVBox/EnableGenreDetectionCheckBox" to="." method="_on_enable_genre_detection_toggled"]
[connection signal="toggled" from="ContentVBox/EnableStemsCheckBox" to="." method="_on_enable_stems_toggled"]
[connection signal="toggled" from="ContentVBox/ShowGenNotifsCheckBox" to="." method="_on_show_gen_notifs_toggled"]
[connection signal="pressed" from="ContentVBox/SongsFolderHBox/ChooseSongsFolderButton" to="." method="_on_choose_songs_folder_pressed"]
[connection signal="pressed" from="ContentVBox/ScanSongsButton" to="." method="_on_scan_songs_pressed"]
[connection signal="confirmed" from="ResetConfirmDialog" to="." method="_confirm_reset_profile_stats"]
[connection signal="dir_selected" from="SongsFolderDialog" to="." method="_on_songs_folder_dir_selected"]
[connection signal="confirmed" from="MigratePathsDialog" to="." method="_on_migrate_paths_confirmed"]
