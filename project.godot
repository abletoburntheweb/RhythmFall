; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="RhythmFall"
run/main_scene="uid://5vghv31ksise"
config/use_custom_user_dir=true
config/custom_user_dir_name="RhythmFall"
config/features=PackedStringArray("4.5", "Forward Plus")
config/icon="uid://lyk67yko8cka"

[autoload]

PlayerDataManager="*res://logic/player_data_manager.gd"
TrackStatsManager="*res://logic/track_stats_manager.gd"
SettingsManager="*res://logic/settings_manager.gd"
MusicManager="*res://logic/music_manager.gd"
SongLibrary="*res://logic/song_library.gd"
Console="*res://addons/console/console.gd"
DebugCommands="*res://addons/console/debug_commands.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=1

[editor_plugins]

enabled=PackedStringArray("res://addons/MusicMetadata/plugin.cfg", "res://addons/console/plugin.cfg")

[gui]

theme/custom_font="uid://dlkdapepenx4"

[rendering]

textures/canvas_textures/default_texture_filter=2
textures/default_filters/use_nearest_mipmap_filter=true
textures/default_filters/anisotropic_filtering_level=4
anti_aliasing/quality/msaa_2d=3
anti_aliasing/quality/screen_space_aa=1
